{
  "name": "gaps-qa",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:server": "tsx watch server/src/main.ts",
    "dev:web": "vite --config web/vite.config.ts",
    "build:web": "vite build --config web/vite.config.ts",
    "build:server": "tsc -p server/tsconfig.json --noEmit",
    "build": "npm run build:web && npm run build:server",
    "check": "tsc -p shared/tsconfig.json --noEmit && tsc -p runners/tsconfig.json --noEmit && tsc -p server/tsconfig.json --noEmit && tsc -p web/tsconfig.json --noEmit",
    "start": "tsx server/src/main.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@modelcontextprotocol/ext-apps": "^1.7.4",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "playwright": "^1.61.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^24.13.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "tsx": "^4.23.1",
    "typescript": "^5.9.2",
    "vite": "^7.3.6",
    "vitest": "^3.2.7"
  }
}
